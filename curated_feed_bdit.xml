      <link>https://samakal.com/opinion/article/344385/%E0%A6%86%E0%A6%AA%E0%A6%A8%E0%A6%BE%E0%A6%B0-%E0%A6%A1%E0%A6%BF%E0%A6%97%E0%A7%8D%E0%A6%B0%E0%A6%BF-%E0%A6%B8%E0%A6%AE%E0%A7%8D%E0%A6%AA%E0%A6%A6-%E0%A6%A8%E0%A6%BE%E0%A6%95%E0%A6%BF-%E0%A6%AC%E0%A7%87%E0%A6%95%E0%A6%BE%E0%A6%B0%E0%A6%A4%E0%A7%8D%E0%A6%AC%E0%A7%87%E0%A6%B0-%E0%A6%B8%E0%A6%A8%E0%A6%A6-</link>
      <guid isPermaLink="true">https://samakal.com/opinion/article/344385/%E0%A6%86%E0%A6%AA%E0%A6%A8%E0%A6%BE%E0%A6%B0-%E0%A6%A1%E0%A6%BF%E0%A6%97%E0%A7%8D%E0%A6%B0%E0%A6%BF-%E0%A6%B8%E0%A6%AE%E0%A7%8D%E0%A6%AA%E0%A6%A6-%E0%A6%A8%E0%A6%BE%E0%A6%95%E0%A6%BF-%E0%A6%AC%E0%A7%87%E0%A6%95%E0%A6%BE%E0%A6%B0%E0%A6%A4%E0%A7%8D%E0%A6%AC%E0%A7%87%E0%A6%B0-%E0%A6%B8%E0%A6%A8%E0%A6%A6-</guid>
      <description>ধীরে ধীরে বিশ্ববিদ্যালয়ের আসন সংখ্যা কমিয়ে কর্মমুখী শিক্ষায় বিনিয়োগ বাড়ানো জরুরি। কারণ আমাদের শুধু অনার্স-মাস্টার্স পাস করা বেকার দরকার নেই আমাদের দরকার দক্ষ কর্মী, উদ্ভাবক, এবং উদ্যোক্তা। একজন দক্ষ ইলেকট্রিশিয়ান, একজন আধুনিক কৃষক, একজন ফুড উদ্যোক্তা তারা শুধু নিজের কর্মসংস্থানই তৈরি করে না, বরং অন্যদের জন্যও কাজের সুযোগ সৃষ্টি করে। অথচ আমরা এখনো এই পেশাগুলোকে সামাজিকভাবে কম মূল্য দেই।</description>
      <pubDate>Sat, 28 Mar 2026 09:28:29 +0600</pubDate>
    </item>
